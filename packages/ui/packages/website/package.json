{
  "name": "@webjsdev/ui-website",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "imports": {
    "#app/*": "./app/*",
    "#components/*": "./components/*",
    "#db/*": "./db/*",
    "#lib/*": "./lib/*",
    "#modules/*": "./modules/*"
  },
  "description": "Registry host + docs site for @webjsdev/ui. Serves /r/<name>.json and renders per-component docs.",
  "scripts": {
    "dev": "webjs dev --port ${PORT:-5003}",
    "start": "webjs start",
    "css:build": "tailwindcss -i ./public/input.css -o ./public/tailwind.css --minify",
    "preview:build": "node scripts/copy-registry.js"
  },
  "webjs": {
    "dev": {
      "before": ["node scripts/copy-registry.js"],
      "parallel": ["tailwindcss -i ./public/input.css -o ./public/tailwind.css --watch"]
    },
    "start": { "before": ["node scripts/copy-registry.js", "npm run css:build"] }
  },
  "dependencies": {
    "@webjsdev/cli": "^0.10.0",
    "@webjsdev/core": "^0.7.0",
    "@webjsdev/server": "^0.8.0",
    "@webjsdev/ui-registry": "*"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^24.0.0"
  }
}
