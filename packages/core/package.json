{
  "name": "@webjsdev/core",
  "version": "0.7.8",
  "type": "module",
  "description": "webjs core runtime - html/css tags, WebComponent base, isomorphic renderers",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "source": "./index.js",
      "default": "./dist/webjs-core.js"
    },
    "./directives": {
      "source": "./src/directives.js",
      "default": "./dist/webjs-core-browser.js"
    },
    "./context": {
      "source": "./src/context.js",
      "default": "./dist/webjs-core-browser.js"
    },
    "./task": {
      "source": "./src/task.js",
      "default": "./dist/webjs-core-browser.js"
    },
    "./client-router": {
      "source": "./src/router-client.js",
      "default": "./dist/webjs-core-browser.js"
    },
    "./lazy-loader": {
      "source": "./src/lazy-loader.js",
      "default": "./dist/webjs-core-lazy-loader.js"
    },
    "./testing": {
      "source": "./src/testing.js",
      "default": "./dist/webjs-core-testing.js"
    },
    "./client": "./src/render-client.js",
    "./server": "./src/render-server.js",
    "./component": {
      "types": "./src/component.d.ts",
      "default": "./src/component.js"
    },
    "./registry": "./src/registry.js",
    "./signals": "./src/signal.js",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index-browser.js",
    "index.d.ts",
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:dist": "node ../../scripts/build-framework-dist.js",
    "prepare": "node -e \"require('fs').existsSync('../../scripts/build-framework-dist.js') && require('fs').existsSync('./src/html.js') && require('child_process').execSync('npm run build:dist', {stdio:'inherit'})\""
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webjsdev/webjs.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/webjsdev/webjs#readme",
  "bugs": "https://github.com/webjsdev/webjs/issues",
  "license": "MIT",
  "keywords": [
    "webjs",
    "web-components",
    "ssr",
    "framework",
    "no-build"
  ]
}
