{
  "name": "@webjsdev/server",
  "version": "0.8.40",
  "type": "module",
  "description": "webjs dev/prod server: SSR, router, API, server actions, live reload",
  "main": "index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./check": {
      "types": "./src/check.d.ts",
      "default": "./src/check.js"
    },
    "./testing": {
      "types": "./src/testing.d.ts",
      "default": "./src/testing.js"
    },
    "./webjs-config.schema.json": "./webjs-config.schema.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src",
    "webjs-config.schema.json",
    "README.md"
  ],
  "dependencies": {
    "@webjsdev/core": "^0.7.1",
    "ws": "^8.20.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webjsdev/webjs.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/webjsdev/webjs#readme",
  "bugs": "https://github.com/webjsdev/webjs/issues",
  "license": "MIT",
  "keywords": [
    "webjs",
    "ssr",
    "server",
    "router",
    "dev-server"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "optionalDependencies": {
    "amaro": "^1.1.10"
  }
}
